DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public&sslmode=require"
NEXTAUTH_SECRET="replace_with_long_random_secret"
NEXTAUTH_URL="http://localhost:3000"

# Bootstrap one admin account
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change_this_password"

# Telegram notifications (optional on first start)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# Cloudflare R2 image storage (required for file upload)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_BASE_URL=""
