generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  DONE
  ARCHIVED
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Lead {
  id          String     @id @default(cuid())
  name        String
  phone       String
  productType String
  profile     String
  width       Int
  height      Int
  comment     String?
  estimateMin Int
  estimateMax Int
  locale      String     @default("ru")
  status      LeadStatus @default(NEW)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Comment {
  id        String        @id @default(cuid())
  name      String
  body      String
  rating    Int
  photoUrl  String?
  status    CommentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model GalleryItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CalculatorOption {
  id         String   @id @default(cuid())
  type       String
  key        String
  labelRu    String
  labelUk    String
  multiplier Float    @default(1)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([type, key])
}
